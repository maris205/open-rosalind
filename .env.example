# OpenRouter (default for MVP1)
# Get a key at https://openrouter.ai/settings/keys and paste it here, or
# `cp secrets.local.env .env` if you keep your key in secrets.local.env
# (which is gitignored).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Trace output dir
OPEN_ROSALIND_TRACE_DIR=./traces
