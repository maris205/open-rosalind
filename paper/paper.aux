\@writefile{toc}{\contentsline {section}{\numberline {4}Framework Architecture}{5}{section.4}\protected@file@percent }
\newlabel{sec:framework}{{4}{5}{Framework Architecture}{section.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Atomic Tools and MCP Interfaces}{5}{subsection.4.1}\protected@file@percent }
\newlabel{sec:tools}{{4.1}{5}{Atomic Tools and MCP Interfaces}{subsection.4.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces The Open-Rosalind layered architecture. Atomic tools and MCP-compliant tool interfaces sit at the base; skills compose tools deterministically; the router and agent dispatch single-step queries; and the harness orchestrates bounded multi-step workflows. Each layer carries its own invariant: tools are deterministic and versioned, skills produce typed outputs, the router emits a categorical decision, and the harness enforces a hard step bound.\relax }}{6}{figure.caption.4}\protected@file@percent }
\newlabel{fig:arch}{{3}{6}{The Open-Rosalind layered architecture. Atomic tools and MCP-compliant tool interfaces sit at the base; skills compose tools deterministically; the router and agent dispatch single-step queries; and the harness orchestrates bounded multi-step workflows. Each layer carries its own invariant: tools are deterministic and versioned, skills produce typed outputs, the router emits a categorical decision, and the harness enforces a hard step bound.\relax }{figure.caption.4}{}}
