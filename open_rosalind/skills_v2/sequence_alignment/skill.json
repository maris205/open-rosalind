{
  "name": "sequence_align_pairwise",
  "display_name": "Sequence Align Pairwise",
  "description": "Align two sequences locally or globally and return score, identity, and formatted alignment.",
  "category": "sequence-analysis",
  "version": "1.0.0",
  "evidence_schema": {
    "source": "tool:sequence.align_pairwise"
  },
  "deterministic": true,
  "requires_network": false,
  "local_available": true,
  "safety_level": "safe",
  "dependencies": ["biopython"],
  "tools_used": ["sequence.align_pairwise"],
  "input_schema": {
    "type": "object",
    "properties": {
      "sequence_a": {"type": "string"},
      "sequence_b": {"type": "string"},
      "mode": {"type": "string", "enum": ["global", "local"]}
    },
    "required": ["sequence_a", "sequence_b"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "annotation": {"type": "object"},
      "confidence": {"type": "number"},
      "notes": {"type": "array"},
      "alignment_result": {"type": "object"}
    }
  },
  "examples": [
    {
      "input": {"sequence_a": "ACGT", "sequence_b": "ACCT", "mode": "global"},
      "expects": "identity and alignment score"
    }
  ],
  "mcp_compatible": true,
  "author": "Open-Rosalind",
  "license": "MIT"
}
