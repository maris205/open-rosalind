{
  "name": "mutation_pathogenicity_workflow",
  "display_name": "Mutation Pathogenicity Workflow",
  "description": "Aggregate mutation impact evidence and grounded PubMed support into a constrained pathogenicity workflow.",
  "category": "workflow",
  "version": "1.0.0",
  "evidence_schema": {
    "source": "mutation.diff + ClinVar + UniProt + PubMed"
  },
  "deterministic": true,
  "requires_network": true,
  "local_available": false,
  "safety_level": "network",
  "dependencies": ["requests"],
  "tools_used": [
    "mutation.diff",
    "clinvar.search",
    "uniprot.search",
    "uniprot.fetch",
    "pubmed.search",
    "pubmed.fetch_metadata",
    "pubmed.fetch_abstract"
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "gene_symbol": {"type": "string"},
      "mutation": {"type": "string"},
      "wt": {"type": "string"},
      "mt": {"type": "string"},
      "wild_type": {"type": "string"},
      "mutant": {"type": "string"},
      "query": {"type": "string"},
      "clinvar_query": {"type": "string"},
      "max_results": {"type": "integer", "minimum": 1, "maximum": 10, "default": 5}
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "annotation": {"type": "object"},
      "confidence": {"type": "number"},
      "notes": {"type": "array"},
      "evidence": {"type": "array"},
      "mutation_result": {"type": "object"},
      "literature_result": {"type": "object"},
      "trace": {"type": "array"}
    }
  },
  "examples": [
    {
      "input": {"gene_symbol": "TP53", "mutation": "p.R175H"},
      "expects": "mutation evidence plus PubMed-backed pathogenicity context"
    }
  ],
  "mcp_compatible": true,
  "author": "Open-Rosalind",
  "license": "MIT"
}
