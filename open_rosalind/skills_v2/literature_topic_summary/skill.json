{
  "name": "literature_topic_summary",
  "display_name": "Literature Topic Summary",
  "description": "Search PubMed and build a structured, evidence-grounded topic digest from top titles and abstracts.",
  "category": "knowledge-synthesis",
  "version": "1.0.0",
  "evidence_schema": {
    "source": "PubMed",
    "url": "https://pubmed.ncbi.nlm.nih.gov"
  },
  "deterministic": true,
  "requires_network": true,
  "local_available": false,
  "safety_level": "network",
  "dependencies": ["requests"],
  "tools_used": ["pubmed.search", "pubmed.fetch_metadata", "pubmed.fetch_abstract"],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {"type": "string"},
      "max_results": {"type": "integer", "minimum": 1, "maximum": 10, "default": 5}
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "annotation": {"type": "object"},
      "confidence": {"type": "number"},
      "notes": {"type": "array"},
      "pubmed": {"type": "object"},
      "metadata": {"type": "object"},
      "abstracts": {"type": "object"},
      "topic_summary": {"type": "object"}
    }
  },
  "examples": [
    {
      "input": {"query": "CRISPR base editing", "max_results": 5},
      "expects": "topic digest grounded in top PubMed records"
    }
  ],
  "mcp_compatible": true,
  "author": "Open-Rosalind",
  "license": "MIT"
}
