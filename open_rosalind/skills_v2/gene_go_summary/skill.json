{
  "name": "gene_go_summary",
  "display_name": "Gene GO Summary",
  "description": "Resolve a gene and summarize a top matching GO biological-process term for that gene.",
  "category": "ontology-lookup",
  "version": "1.0.0",
  "evidence_schema": {
    "source": "Ensembl + NCBI Gene + QuickGO"
  },
  "deterministic": true,
  "requires_network": true,
  "local_available": false,
  "safety_level": "network",
  "dependencies": ["requests"],
  "tools_used": [
    "ensembl.lookup_gene",
    "ensembl.fetch_xrefs",
    "ncbi_gene.search_gene",
    "ncbi_gene.fetch_gene",
    "quickgo.search_terms",
    "quickgo.fetch_term"
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {"type": "string"},
      "symbol": {"type": "string"},
      "gene_symbol": {"type": "string"},
      "species": {"type": "string", "default": "homo_sapiens"}
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "annotation": {"type": "object"},
      "confidence": {"type": "number"},
      "notes": {"type": "array"},
      "evidence": {"type": "array"},
      "gene_result": {"type": "object"},
      "go_result": {"type": "object"},
      "trace": {"type": "array"}
    }
  },
  "examples": [
    {
      "input": {"query": "TP53"},
      "expects": "gene identifiers plus a top GO process term"
    }
  ],
  "mcp_compatible": true,
  "author": "Open-Rosalind",
  "license": "MIT"
}
