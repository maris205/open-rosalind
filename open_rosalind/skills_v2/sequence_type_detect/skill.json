{
  "name": "sequence_type_detect",
  "display_name": "Sequence Type Detect",
  "description": "Detect whether an input sequence is DNA, RNA, protein, or unknown.",
  "category": "sequence-analysis",
  "version": "1.0.0",
  "evidence_schema": {
    "source": "tool:sequence.detect_type"
  },
  "deterministic": true,
  "requires_network": false,
  "local_available": true,
  "safety_level": "safe",
  "dependencies": ["biopython"],
  "tools_used": ["sequence.detect_type"],
  "input_schema": {
    "type": "object",
    "properties": {
      "sequence": {"type": "string"}
    },
    "required": ["sequence"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "annotation": {"type": "object"},
      "confidence": {"type": "number"},
      "notes": {"type": "array"},
      "sequence_type": {"type": "object"}
    }
  },
  "examples": [
    {
      "input": {"sequence": "ATGGCCAAATTAA"},
      "expects": "dna type classification"
    }
  ],
  "mcp_compatible": true,
  "author": "Open-Rosalind",
  "license": "MIT"
}
